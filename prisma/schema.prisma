generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum UserRole {
  admin
  customer
  supervisor
  accountant

  @@map("users_role_enum")
}

enum ProjectType {
  villa
  apartment
  residential
  commercial
  industrial

  @@map("projects_projecttype_enum")
}

enum ProjectStatus {
  Inprogress
  OnHold
  Completed

  @@map("projects_initialstatus_enum")
}

enum SupervisorStatus {
  Active
  Inactive
  reject

  @@map("supervisors_status_enum")
}

enum ConstructionStage {
  Foundation
  Framing
  Plumbing___Electrical @map("Plumbing & Electrical")
  Interior_Walls        @map("Interior Walls")
  Painting
  Finishing
  Others

  @@map("daily_updates_constructionstage_enum")
}

enum DailyUpdateStatus {
  draft
  pending
  approved
  rejected
  Approval_Requested @map("Approval Requested")

  @@map("daily_updates_status_enum")
}

enum UpdateType {
  Customer
  Admin

  @@map("update_type_enum")
}

// DocumentType enum removed to allow free-text strings

enum ExpenseCategory {
  Labor
  Equipment
  Permits
  Materials

  @@map("expenses_category_enum")
}

enum ExpenseStatus {
  pending
  approved
  rejected

  @@map("expenses_status_enum")
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded

  @@map("payments_paymentstatus_enum")
}

enum QuotationStatus {
  pending
  approved
  rejected
  locked

  @@map("quotations_status_enum")
}

// ------------------------------------------------------
// MODELS
// ------------------------------------------------------

enum Timezone {
  ET  @map("Eastern Time (ET)")
  CT  @map("Central Time (CT)")
  MT  @map("Mountain Time (MT)")
  PT  @map("Pacific Time (PT)")
  UTC

  @@map("timezones_enum")
}

enum Currency {
  USD @map("USD ($)")
  EUR @map("EUR (€)")
  GBP @map("GBP (£)")
  INR @map("INR (₹)")

  @@map("currencies_enum")
}

enum Language {
  English
  Spanish
  French

  @@map("languages_enum")
}

enum UserStatus {
  pending
  inprogress
  completed

  @@map("users_status_enum")
}

model User {
  userId              String     @id @default(uuid()) @db.Uuid
  userName            String     @db.VarChar(255)
  role                UserRole
  email               String     @db.VarChar(100)
  password            String?    @db.VarChar(255)
  contact             String     @db.VarChar(15)
  status              UserStatus @default(pending)
  estimatedInvestment Decimal?   @db.Decimal(12, 2)
  notes               String?    @db.Text
  companyName         String?    @db.VarChar(255)
  location            String?    @db.VarChar(255)
  requirements        String?    @db.Text
  description         String?    @db.Text

  // General Settings
  timezone Timezone? @default(UTC)
  currency Currency? @default(INR)
  language Language? @default(English)
  address  String?   @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String?  @map("created_by") // Full Name of the Admin/Accountant
  updatedBy String?  @map("updated_by") // Full Name of the last person to edit

  notifications    Notification[]
  quotations       Quotation[]
  projects         Project[]
  documents        Document[]
  refreshTokens    RefreshToken[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [userId])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model Notification {
  notificationId String @id @default(uuid()) @db.Uuid
  userId         String @db.Uuid
  user           User   @relation(fields: [userId], references: [userId])

  message     String  @db.Text
  type        String? @db.VarChar(50) // 'daily_update', 'payment', etc.
  referenceId String? @db.VarChar(255) @map("reference_id")
  isRead      Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notifications")
}

model Supervisor {
  supervisorId String           @id @default(uuid()) @db.Uuid
  fullName     String           @db.VarChar(255)
  email        String           @unique @db.VarChar(100)
  phoneNumber  String           @db.VarChar(15)
  password     String?          @db.VarChar(255)
  status       SupervisorStatus @default(Active)
  approve      String?          @db.VarChar(50)
  rating       Decimal?         @default(0.0) @db.Decimal(2, 1)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  userId String @unique @db.Uuid

  projectId String?   @db.Uuid // Added per user request
  projects  Project[]

  @@map("supervisors")
}

model Project {
  projectId          String        @id @default(uuid()) @db.Uuid
  projectName        String        @db.VarChar(255)
  projectType        ProjectType
  location           String        @db.VarChar(255)
  initialStatus      ProjectStatus
  startDate          String        @db.VarChar(10)
  progress           Int           @default(0)
  expectedCompletion String        @db.VarChar(10)
  totalBudget        Decimal       @db.Decimal(12, 2)
  materialName       String        @db.VarChar(255)
  quantity           Int
  notes              String        @db.Text
  projectManager     String?       @map("project_manager") @db.VarChar(255)
  area               String?       @map("area") @db.VarChar(100)
  numberOfFloors     Int?          @map("number_of_floors")
  priority           String?       @default("Medium") @db.VarChar(50)
  currency           String?       @default("INR") @db.VarChar(20)
  description        String?       @db.Text

  // New Fields Matching UI
  customerId String @db.Uuid
  customer   User   @relation(fields: [customerId], references: [userId])

  supervisorId String?     @db.Uuid
  supervisor   Supervisor? @relation(fields: [supervisorId], references: [supervisorId])

  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  createdBy String?  @map("created_by") // Store Full Name of the Admin/Accountant
  updatedBy String?  @map("updated_by") // Store Full Name of the last person to edit

  dailyUpdates DailyUpdate[]
  documents    Document[]
  expenses     Expense[]
  materials    Material[]
  payments     Payment[]
  quotations   Quotation[]
  messages     Message[]
  purchases    Purchase[]

  @@map("projects")
}

model Message {
  messageId  String  @id @default(uuid()) @db.Uuid
  subject    String? @db.VarChar(255)
  message    String  @db.Text
  senderId   String  @db.Uuid
  sender     User    @relation("SentMessages", fields: [senderId], references: [userId])
  receiverId String  @db.Uuid
  receiver   User    @relation("ReceivedMessages", fields: [receiverId], references: [userId])

  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [projectId])

  parentId String?   @db.Uuid
  parent   Message?  @relation("MessageReplies", fields: [parentId], references: [messageId])
  replies  Message[] @relation("MessageReplies")

  isRead Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("messages")
}

model DailyUpdate {
  dailyUpdateId     String            @id @default(uuid()) @db.Uuid
  constructionStage ConstructionStage @default(Foundation)
  description       String?           @db.Text
  workCompleted     String?           @map("work_completed") @db.VarChar(255)
  rawMaterials      Json?             @default("[]")
  imageUrl          String?           @map("image_url") @db.VarChar(500)
  imageName         String?           @map("image_name") @db.VarChar(255)
  imageType         String?           @map("image_type") @db.VarChar(100)
  imageId           String?           @map("image_id") @db.VarChar(255)
  videoUrl          String?           @map("video_url") @db.VarChar(500)
  videoId           String?           @map("video_id") @db.VarChar(255)
  status            DailyUpdateStatus @default(pending)

  updateType          UpdateType @default(Customer)
  quantityConsumption Json?      @default("[]")
  labourWorkers       Json?      @default("[]")

  feedback          String?    @db.Text

  // Dual-approval flow
  adminApproved     Boolean?   @map("admin_approved")
  customerApproved  Boolean?   @map("customer_approved")
  customerFeedback  String?    @db.Text @map("customer_feedback")

  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [projectId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("daily_updates")
}

model AuthLogin {
  authLoginId String @id @default(uuid()) @db.Uuid
  email       String @db.VarChar(255)
  password    String @db.VarChar(255)

  @@map("auth_login")
}

model Document {
  documentId   String       @id @default(uuid()) @db.Uuid
  documentType String       @default("Others") @db.VarChar(100)
  fileData     Bytes?       @db.ByteA
  fileName     String       @db.VarChar(255)
  fileType     String       @db.VarChar(100)
  fileId       String?      @map("file_id") @db.VarChar(255)
  fileUrl      String?      @db.Text
  fileSize     String?      @map("file_size") @db.VarChar(50)
  description  String?      @db.VarChar(500)

  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [projectId])

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [userId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String?  @map("created_by") // Full Name of the creator
  updatedBy String?  @map("updated_by") // Full Name of the last person to edit

  @@map("documents")
}

model Expense {
  expenseId String @id @default(uuid()) @db.Uuid

  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [projectId])

  category    Json          @default("[]") // Array of objects: { category, workerName, amount, paymentMode }
  amount      Decimal       @db.Decimal(12, 2) // Will still remain as total amount
  date        String        @db.VarChar(10)
  description String?       @db.Text
  status      ExpenseStatus @default(pending)
  receiptUrl  String?       @map("receipt_url") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String?  @map("created_by") // Full Name of the creator
  updatedBy String?  @map("updated_by") // Full Name of the last person to edit

  @@map("expenses")
}

enum MaterialUnit {
  units
  bags
  ton
  kg
  ft
  m
  sqft
  cum

  @@map("materials_unit_enum")
}

model Material {
  materialId String @id @default(uuid()) @db.Uuid

  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [projectId])

  materialName String       @db.VarChar(255)
  quantity     Int
  units        MaterialUnit @default(units)
  date         String       @db.VarChar(10)
  notes        String?      @db.Text
  vendor       String?      @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String?  @map("created_by") // Full Name of the creator
  updatedBy String?  @map("updated_by") // Full Name of the last person to edit

  @@map("materials")
}

enum PaymentType {
  Standard
  MultiMode

  @@map("payments_type_enum")
}

enum PaymentMethod {
  cash
  card
  bank_transfer
  cheque
  online
  UPI

  @@map("payments_paymentmethod_enum")
}

model Payment {
  paymentId String  @id @default(uuid()) @db.Uuid
  amount    Decimal @db.Decimal(12, 2)

  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [projectId])

  paymentStatus  PaymentStatus @default(pending)
  paymentType    PaymentType   @default(Standard) @map("payment_type")
  paymentMethod  PaymentMethod @default(cash)
  paymentBreakup Json?         @default("[]") @map("payment_breakup")
  paymentDate    String        @db.VarChar(10)
  receiptNumber  String?       @map("receipt_number") @db.VarChar(50)
  referenceNumber String?      @map("reference_number") @db.VarChar(20)
  receivedBy     String?       @map("received_by") @db.VarChar(255)
  remarks        String?       @db.Text

  // File upload fields
  fileUrl  String? @map("file_url") @db.Text
  fileId   String? @map("file_id") @db.VarChar(255)
  fileName String? @map("file_name") @db.VarChar(255)
  fileType String? @map("file_type") @db.VarChar(100)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

model Quotation {
  quotationId String          @id @default(uuid()) @db.Uuid
  totalAmount Decimal         @db.Decimal(12, 2)
  status      QuotationStatus @default(pending)
  lineItems   Json?           @default("[]")
  date        String?         @db.VarChar(10)

  projectId String?  @db.Uuid
  project   Project? @relation(fields: [projectId], references: [projectId])

  fileData     Bytes?  @db.ByteA
  fileName     String? @db.VarChar(255)
  fileType     String? @db.VarChar(100)
  fileId       String? @map("file_id") @db.VarChar(255)
  fileUrl      String? @db.Text
  customerName String? @db.VarChar(255)
  feedback     String? @db.Text

  userId String? @db.Uuid
  user   User?   @relation(fields: [userId], references: [userId])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy String?  @map("created_by") // Full Name of the creator
  updatedBy String?  @map("updated_by") // Full Name of the last person to edit

  @@map("quotations")
}

model TokenBlacklist {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("token_blacklist")
}

// -------------------------------------------------------
// EMAIL LOGS — tracks every email send attempt
// -------------------------------------------------------
model EmailLog {
  id        String   @id @default(uuid()) @db.Uuid
  to        String   @db.VarChar(255)
  subject   String   @db.VarChar(500)
  status    String   @default("sent") @db.VarChar(20) // "sent" | "failed"
  resendId  String?  @map("resend_id") @db.VarChar(255) // ID returned by Resend
  error     String?  @db.Text // Error message if failed
  event     String?  @db.VarChar(100) // e.g. "project_assigned", "payment_verified"
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_logs")
}

// -------------------------------------------------------
// PURCHASES
// -------------------------------------------------------
model Purchase {
  id             Int      @id @default(autoincrement())
  projectId      String   @db.Uuid
  project        Project  @relation(fields: [projectId], references: [projectId])
  materialName   String   @db.VarChar(255)
  price          Decimal  @db.Decimal(12, 2)
  vendorDetails  String?  @db.VarChar(255)            @map("vendor_details")
  dateOfPurchase String?  @db.VarChar(50)             @map("date_of_purchase")
  quantity       Decimal? @db.Decimal(12, 2)
  unit           String?  @db.VarChar(50)
  transportAmt   Decimal? @db.Decimal(12, 2) @map("transport_amt")
  vendorPay      Decimal? @db.Decimal(12, 2) @map("vendor_pay")
  totalPrice     Decimal? @db.Decimal(12, 2) @map("total_price")
  dueAmount      Decimal? @db.Decimal(12, 2) @map("due_amount")
  createdAt      DateTime @default(now()) @map("created_at")

  createdBy String?  @map("created_by") // Full Name of the creator
  updatedBy String?  @map("updated_by") // Full Name of the last person to edit

  @@map("purchases")
}

